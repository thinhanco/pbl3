    <!-- JAVASCRIPT -->
    <script>
      // 1. Chức năng Toggle Menu cho Mobile
      const menuToggle = document.getElementById("menu-toggle");
      const navMenu = document.getElementById("nav-menu");

      menuToggle.addEventListener("click", () => {
        navMenu.classList.toggle("active");
        // Đổi icon từ hamburger sang dấu X
        if (navMenu.classList.contains("active")) {
          menuToggle.classList.remove("fa-bars");
          menuToggle.classList.add("fa-times");
        } else {
          menuToggle.classList.remove("fa-times");
          menuToggle.classList.add("fa-bars");
        }
      });

      // 2. Chức năng Sticky Header (Đổi nền khi scroll)
      const header = document.getElementById("header");

      window.addEventListener("scroll", () => {
        if (window.scrollY > 50) {
          // Sử dụng biến CSS để thay đổi nền thay vì hardcode
          header.style.backgroundColor = "var(--bg-white)";
          header.style.boxShadow = "var(--shadow-light)";
        } else {
          header.style.backgroundColor = "var(--bg-transparent)";
          header.style.boxShadow = "none";
        }
      });

      // 3. Xử lý form Booking (Mô phỏng)
      const bookingForm = document.getElementById("booking-form");
      bookingForm.addEventListener("submit", (e) => {
        e.preventDefault(); // Ngăn chặn load lại trang
        alert(
          "Cảm ơn bạn! Hệ thống đang kiểm tra phòng trống. Chúng tôi sẽ chuyển hướng bạn sang trang thanh toán.",
        );
      });
      // 4. Chức năng Lướt (Slider) cho danh sách phòng
      const roomsGridEl = document.getElementById("rooms-grid");
      const btnLeft = document.getElementById("slide-left");
      const btnRight = document.getElementById("slide-right");

      // Bấm nút phải: Lướt sang phải 350px (tương đương 1 thẻ phòng + khoảng cách)
      btnRight.addEventListener("click", () => {
        roomsGridEl.scrollBy({
          top: 0,
          left: 350,
          behavior: "smooth",
        });
      });

      // Bấm nút trái: Lướt sang trái 350px
      btnLeft.addEventListener("click", () => {
        roomsGridEl.scrollBy({
          top: 0,
          left: -350,
          behavior: "smooth",
        });
      });
    </script>
