@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Hotel Vip</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --primary-color: #d4af37; --secondary-color: #1a252f;
            --bg-overlay: rgba(0, 0, 0, 0.7); --text-white: #ffffff;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: "Poppins", sans-serif;
            background: url("https://anviethouse.vn/wp-content/uploads/2021/12/Thiet-ke-phong-khach-san-phong-cach-indochine-1-2.jpg") center/cover no-repeat;
            height: 100vh; display: flex; align-items: center; justify-content: center; position: relative;
        }
        body::before {
            content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-color: var(--bg-overlay); backdrop-filter: blur(5px);
        }
        .auth-container { position: relative; z-index: 1; background: white; width: 100%; max-width: 400px; padding: 2rem; border-radius: 12px; }
        .logo-title { font-family: "Playfair Display", serif; color: var(--primary-color); text-align: center; font-size: 2.5rem; margin-bottom: 1.5rem; }
        .floating-group { position: relative; margin-bottom: 1.5rem; }
        .floating-group input { width: 100%; padding: 20px 15px 5px; border: 1px solid #ddd; border-radius: 6px; outline: none; }
        .floating-group label { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); transition: 0.2s; color: #888; pointer-events: none; }
        .floating-group input:focus ~ label, .floating-group input:not(:placeholder-shown) ~ label { top: 10px; font-size: 0.7rem; color: var(--primary-color); }
        .btn-submit { width: 100%; padding: 12px; background: var(--primary-color); color: white; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; }
        
        /* SỬA LỖI MEDIA QUERY */
        @@media (max-width: 576px) {
            .auth-container { margin: 0 15px; }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="logo-title">Hotel Vip</div>
        <form asp-controller="Account" asp-action="Login" method="post">
            <div class="floating-group">
                <input type="text" name="username" placeholder=" " required />
                <label>Tên đăng nhập</label>
            </div>
            <div class="floating-group">
                <input type="password" name="password" placeholder=" " required />
                <label>Mật khẩu</label>
            </div>
            <button type="submit" class="btn-submit">ĐĂNG NHẬP</button>
        </form>
        <div style="text-align:center; margin-top: 1rem;">
            <a href="/" style="color: #666; text-decoration: none; font-size: 0.9rem;"><i class="fas fa-arrow-left"></i> Về trang chủ</a>
        </div>
    </div>
</body>
</html>
